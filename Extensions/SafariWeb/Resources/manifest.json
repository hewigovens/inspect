{
  "manifest_version": 3,
  "name": "Web: Inspect Certificate",
  "description": "Inspect the current page TLS certificate.",
  "version": "2.4.0",
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.png"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging"
  ]
}
